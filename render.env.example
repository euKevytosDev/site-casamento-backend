# Variáveis OBRIGATÓRIAS no Render → Environment

DB_URL=jdbc:postgresql://HOST/neondb?sslmode=require
DB_USERNAME=seu_usuario_neon
DB_PASSWORD=sua_senha_neon

# Gere com: openssl rand -base64 48
JWT_SECRET=cole_aqui_uma_chave_com_pelo_menos_32_caracteres

ADMIN_LOGIN=admin
ADMIN_PASSWORD=defina_uma_senha_forte_com_8_ou_mais_caracteres

# Opcional — schema (padrão: none). Só use update em ambiente novo.
# DDL_AUTO=none

# Cloudinary — imagens dos presentes
CLOUDINARY_CLOUD_NAME=ppkccbhu
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=sua_api_secret
CLOUDINARY_FOLDER=presentes-casamento

# PIX — chave cadastrada no seu banco (CPF, e-mail, telefone ou aleatória)
PIX_CHAVE=sua_chave_pix_aqui
PIX_NOME_RECEBEDOR=Maria e Joao
PIX_CIDADE=Sao Paulo

# Asaas — assinatura SaaS (landing checkout)
# Integrações → API Key (produção: api.asaas.com | sandbox: api-sandbox.asaas.com)
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com
# Token que você define no webhook Asaas (header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=
# URL do webhook no painel Asaas:
#   https://site-casamento-backend-nrfb.onrender.com/api/webhooks/asaas
# Eventos: PAYMENT_CONFIRMED, PAYMENT_RECEIVED, PAYMENT_OVERDUE, PAYMENT_REFUNDED,
#          PAYMENT_DELETED, SUBSCRIPTION_DELETED (se disponível)
ASAAS_BACK_URL_SUCCESS=https://somosloven.com/sucesso.html
ASAAS_VALOR_MENSAL=59.90

# Mercado Pago — presentes no cartão (OAuth) + webhooks legados
# Credenciais: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_NOTIFICATION_URL=https://site-casamento-backend-nrfb.onrender.com/api/webhooks/mercadopago
MERCADOPAGO_PREAPPROVAL_PLAN_ID=
MERCADOPAGO_BACK_URL_SUCCESS=https://somosloven.com/sucesso.html
MERCADOPAGO_BACK_URL_FAILURE=https://somosloven.com/
MERCADOPAGO_VALOR_MENSAL=59.90
