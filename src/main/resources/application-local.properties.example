# Copie este arquivo para application-local.properties e preencha os valores.
# O arquivo application-local.properties NÃO deve ser commitado no Git.

DB_URL=jdbc:postgresql://SEU_HOST/neondb?sslmode=require
DB_USERNAME=seu_usuario
DB_PASSWORD=sua_senha_aqui

# Mínimo 32 caracteres — gere uma chave aleatória longa
JWT_SECRET=gere_uma_chave_aleatoria_com_pelo_menos_32_caracteres

ADMIN_LOGIN=admin
ADMIN_PASSWORD=defina_uma_senha_forte_aqui

JWT_EXPIRATION_HOURS=24

# Cloudinary — imagens dos presentes (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
CLOUDINARY_FOLDER=presentes-casamento

# PIX
PIX_CHAVE=sua_chave_pix
PIX_NOME_RECEBEDOR=Maria e Joao
PIX_CIDADE=Sao Paulo

# Mercado Pago — plano único mensal (Assinaturas)
# Na aplicação MP, ative o produto Assinaturas.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_NOTIFICATION_URL=https://SEU-BACKEND.onrender.com/api/webhooks/mercadopago
MERCADOPAGO_BACK_URL_SUCCESS=https://somosloven.com/sucesso.html
MERCADOPAGO_BACK_URL_FAILURE=https://somosloven.com/
MERCADOPAGO_VALOR_MENSAL=59.90
MERCADOPAGO_PERMANENCIA_MINIMA_MESES=6
